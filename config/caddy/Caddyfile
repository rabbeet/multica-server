# Caddyfile — TLS reverse proxy bound to tailnet IP only.
#
# Caddy serves multica web UI at https://multica.<tailnet>.ts.net.
# Cert and key come from `tailscale cert` (auto-renewed).
# Listens ONLY on the tailnet interface — public IP cannot reach this Caddy.

{
	# Disable telemetry, OCSP stapling fallback
	auto_https off
	admin off
}

# ==============================================================================
# multica.{tailnet}.ts.net — main entry point
# ==============================================================================
{$TAILSCALE_HOSTNAME}.{$TAILNET_NAME} {
	# TLS via Tailscale — Caddy reads the cert/key from /var/lib/tailscale.
	# Tailscale provisions these via `tailscale cert` (called in 03-tailscale-up.sh).
	#
	# Caddy needs the actual file paths — Tailscale stores them as:
	#   /var/lib/tailscale/certs/{hostname}.{tailnet}.ts.net.crt
	#   /var/lib/tailscale/certs/{hostname}.{tailnet}.ts.net.key
	tls /var/lib/tailscale/certs/{$TAILSCALE_HOSTNAME}.{$TAILNET_NAME}.crt /var/lib/tailscale/certs/{$TAILSCALE_HOSTNAME}.{$TAILNET_NAME}.key

	# Listen on tailnet IP only — Tailscale assigns 100.x.y.z range.
	# We bind via the tailscale0 interface; public eth0 is NOT bound.
	bind tailscale0

	# Reverse-proxy to multica daemon
	reverse_proxy {$MULTICA_BACKEND} {
		# Pass real client info for logging
		header_up X-Real-IP {http.request.remote.host}
		header_up X-Forwarded-Proto {http.request.scheme}

		# WebSocket support (multica streams agent activity)
		flush_interval -1
	}

	# Strict transport — only over HTTPS
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"
	header Referrer-Policy "no-referrer"

	# Local health endpoint (used by 99-verify.sh)
	handle /health {
		respond "multica caddy alive" 200
	}

	# Logging
	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
		level INFO
	}
}

# ==============================================================================
# Localhost — used by docker compose healthcheck
# ==============================================================================
:80 {
	bind 127.0.0.1
	respond /health "ok" 200
	respond / "redirected to https" 308
}
